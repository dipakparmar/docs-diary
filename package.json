{
  "name": "docs-diary",
  "version": "1.9.0",
  "private": true,
  "repository": {
    "type": "git",
    "url": "git+https://github.com/dipakparmar/docs-diary.git"
  },
  "scripts": {
    "docusaurus": "docusaurus",
    "start": "docusaurus start",
    "build": "docusaurus build",
    "swizzle": "docusaurus swizzle",
    "deploy": "docusaurus build && wrangler deploy",
    "clear": "docusaurus clear",
    "serve": "docusaurus serve",
    "write-translations": "docusaurus write-translations",
    "write-heading-ids": "docusaurus write-heading-ids",
    "typecheck": "tsc",
    "ci": "bun run lint && bun run format:diff",
    "lint": "eslint \"**/*.js\" \"**/*.ts\"",
    "format": "prettier --config .prettierrc --write \"**/*.{js,jsx,ts,tsx,md,mdx}\"",
    "format:diff": "prettier --config .prettierrc --list-different \"**/*.{js,jsx,ts,tsx,md,mdx}\"",
    "yml-to-json": "node scripts/yml-to-json.js"
  },
  "dependencies": {
    "@dipakparmar/docusaurus-plugin-umami": "2.4.0",
    "@docusaurus/core": "3.9.1",
    "@docusaurus/plugin-client-redirects": "3.9.1",
    "@docusaurus/plugin-content-docs": "3.9.1",
    "@docusaurus/preset-classic": "3.9.1",
    "@docusaurus/theme-common": "3.9.1",
    "@docusaurus/theme-mermaid": "3.9.1",
    "@mdx-js/react": "3.0.1",
    "clsx": "2.1.1",
    "prism-react-renderer": "2.3.1",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "react-gist": "1.2.4",
    "reading-time": "1.5.0",
    "roughjs": "^4.6.6"
  },
  "devDependencies": {
    "@babel/eslint-parser": "7.25.1",
    "@docusaurus/eslint-plugin": "^3.4.0",
    "@docusaurus/module-type-aliases": "^3.4.0",
    "@docusaurus/tsconfig": "3.9.1",
    "@docusaurus/types": "^3.9.1",
    "@giscus/react": "3.0.0",
    "@semantic-release/changelog": "6.0.3",
    "@semantic-release/git": "10.0.1",
    "@types/react": "^18.3.3",
    "eslint": "8.57.0",
    "eslint-config-airbnb": "19.0.4",
    "eslint-config-prettier": "9.1.0",
    "eslint-plugin-header": "3.1.1",
    "eslint-plugin-import": "2.32.0",
    "eslint-plugin-jsx-a11y": "6.10.2",
    "eslint-plugin-react": "7.34.1",
    "eslint-plugin-react-hooks": "4.6.2",
    "prettier": "3.2.5",
    "semantic-release": "25.0.3",
    "stylelint": "16.6.1",
    "typescript": "5.5.4",
    "wrangler": "^4.107.1"
  },
  "resolutions": {
    "nth-check": "2.0.1",
    "trim": "0.0.3",
    "axios": "1.6.0",
    "webpack": "5.101.3"
  },
  "trustedDependencies": ["esbuild", "sharp", "workerd"],
  "browserslist": {
    "production": [
      "last 2 Chrome versions",
      "last 2 Firefox versions",
      "last 2 Safari versions",
      "last 2 Edge versions",
      "not dead"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "engines": {
    "node": ">=24.0"
  }
}
